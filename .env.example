# === Notion API 설정 ===
NOTION_API_KEY=

# === 2026 봄학기 수업 (자동 스캔) ===
# Courses 페이지
NOTION_COURSES_PAGE_ID=2a45ddaf-3b4b-81f4-b715-f5f7f98b445a
# 수업 목록 DB (모든 수업 자동 스캔)
NOTION_COURSES_DB_ID=2a45ddaf-3b4b-8135-94f4-cbf885bd8c14
# 오늘의 퀴즈 DB (주차별 퀴즈 업로드)
NOTION_QUIZ_DB_ID=3205ddaf-3b4b-8095-acf3-d9a76286f24a
# 학기 시작일 (주차 계산용)
SEMESTER_START_DATE=2026-03-03
# 제외할 수업 (쉼표로 구분, 시험 안 보는 수업 등)
EXCLUDED_COURSES=언어공학캡스톤디자인

# === LLM 설정 (Ollama) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=solar

